    subgraph EventTracking["Event Tracking (10 Base) - POR IMPLEMENTAR"]
        ConvStarted["conversation_started"]:::event
        MenuOption["menu_option_selected"]:::event
        ServiceSel["service_selected"]:::event
        FallbackTrig["fallback_triggered"]:::event
        AppointmentCreated["appointment_created"]:::event
        Escalation["escalation_to_human"]:::event
        CSAT["csat_submitted"]:::event
        ReminderSent["reminder_sent"]:::event
        ReminderResp["reminder_response"]:::event
        ConvClosed["conversation_closed"]:::event
    end

    classDef event fill:#fff3e0,stroke:#ff9800,stroke-width:2px;

    %% ============================
    %% MÉTRICAS CRÍTICAS (12 Total)
    %% ============================

    subgraph "Metrics Database"
        MetricsDB[(Metrics DB - PostgreSQL)]
        
        ConvRate["#1: Conversión inicio→turno"]:::metric
        PctBotTurnos["#2: % turnos creados por bot"]:::metric
        AbandonoRate["#3: Abandono por paso"]:::metric
        FallbackRate["#4: Tasa fallback"]:::metric
        TopFallbacks["#5: Top 10 fallbacks"]:::metric
        NocturnoPct["#6: % turnos nocturnos"]:::metric
        ResolucionRate["#7: Resolución autónoma"]:::metric
        CancelRate["#8: Tasa cancelación"]:::metric
        NoShowRate["#9: Tasa no-show"]:::metric
        ConfirmRate["#10: Confirmación recordatorio"]:::metric
        TopServicios["#11: Servicios más reservados"]:::metric
        CSATAvg["#12: CSAT promedio"]:::metric
    end

    classDef metric fill:#e8f4fc,stroke:#3b82f6,stroke-width:2px;

    %% ============================
    %% DASHBOARD & REPORTING
    %% ============================

    subgraph "Analytics Engine"
        Grafana["Grafana Dashboard"]
        Stats["Conversation Statistics<br/>Aggregated Metrics"]
    end

    subgraph "Event Store"
        Events[(Events - Event Log)]
    end


    %% ============================
    %% CONEXIONES - Leyenda: --> = implementado | -.- = pendiente
    %% ============================

    Users -->|Sends Message| Meta
    LandingPage & MarketingPage -.- Users
    GoogleAuth -->|OAuth Flow| AuthConfig
    AuthConfig -->|POST /auth/google| Auth
    LoginPage & RegisterPage -.- Users
    DashboardPage & OnboardingPage -.- OperatorRole
    
    Meta -->|Webhook Event| Webhook
    Webhook -->|Processes Data| ChatbotRouter
    Webhook -.-|Calls API| Catalog
    
    ChatbotRouter -->|Internal Logic| WhatsAppService
    ChatbotRouter -->|State Management| StateManager
    WhatsAppService -->|Calls API| Meta
    
    ChatbotRouter -.- DB_Logic
    StateManager -.- Redis
    Security -.- Webhook
    Settings -.- Webhook

    %% ============================
    %% CI/CD CONNECTIONS
    %% ============================

    CIWorkflow -.-|Runs on push| FrontendApp
    CIWorkflow -.-|Runs on push| BE

    %% ============================
    %% DEPLOYMENT CONNECTIONS
    %% ============================

    DockerCompose -->|Orquesta| APIContainer
    DockerCompose -->|Orquesta| FrontContainer
    DockerCompose -->|Orquesta| DBContainer
    DockerCompose -->|Orquesta| RedisContainer
    
    APIContainer -->|Ejecuta| Webhook
    FrontContainer -->|Sirve| FrontendApp
    DBContainer -->|Persiste datos| DBVolumen
    RedisContainer -->|Persiste datos| RedisVolumen
    
    DBContainer -.-|Backend conecta vía| PG
    RedisContainer -.-|Backend conecta vía| Redis

    %% ============================
    %% INTEGRACIÓN DE EVENTOS EN METRICS DB
    %% ============================

    Events -.- ConvStarted
    Events -.- MenuOption
    Events -.- ServiceSel
    Events -.- FallbackTrig
    Events -.- AppointmentCreated
    Events -.- Escalation
    Events -.- CSAT
    Events -.- ReminderSent
    Events -.- ReminderResp
    Events -.- ConvClosed

    %% ============================
    %% CÁLCULO DE MÉTRICAS
    %% ============================

    ChatbotRouter -.- Stats
    Stats -.-|Calculates| MetricsDB
    
    ConvRate ~~~ Stats
    PctBotTurnos ~~~ Stats
    AbandonoRate ~~~ Stats
    FallbackRate ~~~ Stats
    TopFallbacks ~~~ Stats
    NocturnoPct ~~~ Stats
    ResolucionRate ~~~ Stats
    CancelRate ~~~ Stats
    NoShowRate ~~~ Stats
    ConfirmRate ~~~ Stats
    TopServicios ~~~ Stats
    CSATAvg ~~~ Stats

    %% ============================
    %% PERSISTENCIA Y VISUALIZACIÓN
    %% ============================

    MetricsDB -.- Grafana
    
    MetricsDB -.-|Stores Data| PG
    MetricsDB -.-|Caches Data| Redis