    end

    style CICD fill:#fce4ec,stroke:#e91e63,stroke-width:2px

    %% ============================
    %% DEPLOYMENT - Docker Compose
    %% ============================

    subgraph DockerDeploy["Deployment (Docker Compose)"]
        direction TB
        
        DockerCompose["docker-compose.yml<br/>Orquestación de 4 servicios"]
        
        APIContainer["API Container<br/>backend/Dockerfile<br/>Python 3.11-slim<br/>Port: 8000"]
        FrontContainer["Frontend Container<br/>frontend/Dockerfile<br/>Node 22-alpine<br/>Port: 3000"]
        DBContainer["PostgreSQL Container<br/>postgres:16-alpine<br/>Port: 5432"]
        RedisContainer["Redis Container<br/>redis:7-alpine<br/>Port: 6379"]
        
        DBVolumen[("Volume: chatbot_postgres_data")]
        RedisVolumen[("Volume: chatbot_redis_data")]
    end

    style DockerDeploy fill:#e8eaf6,stroke:#5c6bc0,stroke-width:2px

    %% ============================
