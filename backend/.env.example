# =============================================================================
# WhatsApp Cloud API (Meta)
# Obtener desde: https://developers.facebook.com/apps → tu app → WhatsApp → API Setup
# =============================================================================
WHATSAPP_PHONE_NUMBER_ID=          # ID del número de teléfono (número de prueba o real)
WHATSAPP_BUSINESS_ACCOUNT_ID=      # ID de la cuenta WABA
WHATSAPP_ACCESS_TOKEN=             # Token del System User (nunca expira) — ver docs/06-deployment/env-variables.md
WHATSAPP_VERIFY_TOKEN=             # Token secreto para verificar el webhook (inventalo vos, ej: "mi_token_secreto_123")

# =============================================================================
# Meta App
# Obtener desde: https://developers.facebook.com/apps → Configuración → Básica
# =============================================================================
META_APP_ID=
META_APP_SECRET=

# =============================================================================
# Base de datos
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/chatbot_db

# =============================================================================
# Aplicación
# =============================================================================
APP_ENV=development                # development | staging | production
APP_PORT=3000
SECRET_KEY=                        # Clave secreta para JWT (generar con: openssl rand -hex 32)

# =============================================================================
# Ngrok (solo desarrollo local)
# Necesario para exponer el webhook a Meta
# =============================================================================
NGROK_AUTHTOKEN=                   # Opcional: token de ngrok para sesiones persistentes
