# Forzar a que Git maneje los finales de línea automáticamente
* text=auto

# Asegurar que archivos clave mantengan el formato Linux (LF) dentro del contenedor
*.py text eol=lf
*.sh text eol=lf
*.env* text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf
requirements.txt text eol=lf

# Archivos donde no queremos que Git toque nada (binarios/imágenes)
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text