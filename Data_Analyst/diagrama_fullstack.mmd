    %% ============================
    %% BACKEND Application (FastAPI)
    %% ============================

    subgraph BE["Backend (FastAPI 0.110)"]
        subgraph "API Routers"
            Auth["/api/v1/auth/login.py<br/>Auth (mock + Google)"]
            Catalog["/api/v1/catalog/<br/>productos.py + servicios.py"]
            Calendar["/api/v1/calendar/turnos.py<br/>Calendar"]
            FAQ["/api/v1/faq/router.py<br/>FAQ"]
            ChatbotRouter["/api/v1/chatbot/<br/>chat.py + webhook.py"]
            Admin["/api/v1/admin/negocio.py<br/>Admin"]
        end

        Webhook["Webhook Entry<br/>GET verify + POST receive"]

        subgraph "Core Services"
            WhatsAppService["services/whatsapp.py<br/>(WhatsApp Integration ✓)"]
            DB_Logic["app/db/database.py<br/>(Engine síncrono SQLAlchemy)<br/>app/db/models/ (VACÍO ❌)"]
        end

        subgraph "Infrastructure"
            Settings["app/core/settings.py<br/>(Configuration ✓)"]
            Security["app/core/security.py<br/>(JWT + OAuth2 ✓)"]
            Schemas["app/schemas/<br/>auth, catalog, calendar, chat, faq, admin"]
        end

        subgraph "Databases / External APIs"
            PG[(PostgreSQL - Main DB)]
            Redis[(Redis Cache)]
        end

        subgraph "Permissions"
            AdminRole["ADMIN: Full Access"]
            OperatorRole["OPERATOR: Limited"]
            GuestRole["GUEST: Read-Only"]
        end
    end

    style BE fill:#fff9c4,stroke:#f57f17,stroke-width:2px

